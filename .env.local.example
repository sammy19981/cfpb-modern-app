# Copy this file to .env.local and fill in your keys.

# OpenAI — required for the 6-agent pipeline
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Resend — required for the "Send Resolution Email" button in the app.
# Get a free key at https://resend.com. Free tier includes 100 emails/day.
# Without RESEND_FROM_EMAIL, sends use Resend's sandbox sender which can
# only deliver to the email address on your Resend account.
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=CFPB Resolution Agent <onboarding@resend.dev>
