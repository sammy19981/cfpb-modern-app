# Copy this file to .env.local and fill in your keys.

# OpenAI — required for the 6-agent pipeline
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Gmail SMTP — required for the "Send Resolution Email" button in the app.
# FREE. No domain needed. Works with any Gmail account.
#
# Setup (5 minutes):
#   1. Enable 2-Step Verification on your Google account:
#      https://myaccount.google.com/security
#   2. Create an App Password (you cannot use your normal Gmail password):
#      https://myaccount.google.com/apppasswords
#      Choose "Mail" + "Other (Custom name)" → name it "CFPB Agent"
#   3. Google generates a 16-character password — paste it below (no spaces)
#   4. Put your Gmail address in GMAIL_USER
#
# Sends from your Gmail address to ANY recipient (no domain verification).
# Gmail free tier: 500 emails/day — plenty for a demo.
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=your16charapppassword
GMAIL_FROM_NAME=CFPB Resolution Agent
